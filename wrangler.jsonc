{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "genshin-calculator",
  "main": "cloudflare-worker.mjs",
  "compatibility_date": "2026-06-20",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
