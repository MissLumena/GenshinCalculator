# === Сервер ===
APP_HOST=0.0.0.0
APP_PORT=8010
APP_DEBUG=true

# Разрешённые origin для CORS (фронтенд Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === JWT (смените в production!) ===
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Приложение ===
APP_NAME=Genshin DPS Calculator API
API_PREFIX=/api

# === Supabase Auth (JWT для проверки Bearer-токена фронтенда) ===
# Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# === Notion (обязательно для раздела «Результаты в Notion») ===
# Можно указать здесь или в корневом .env проекта
NOTION_SECRET=           # notion.so → Settings → Integrations → Internal Integration Token
NOTION_DATABASE_ID=      # ID базы из URL страницы Notion (32 символа, можно вставить ссылку)
NOTION_WEBHOOK_SECRET=     # секрет подписи webhook (если используете POST /api/notion/webhook)
NOTION_STARTUP_CHECK=true
NOTION_VERSION=2022-06-28
NOTION_TIMEOUT_SECONDS=15
