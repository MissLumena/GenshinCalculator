# === Сервер ===
APP_HOST=0.0.0.0
APP_PORT=8010
APP_DEBUG=true

# Разрешённые origin для CORS (фронтенд Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === JWT (смените в production!) ===
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Приложение ===
APP_NAME=Genshin DPS Calculator API
API_PREFIX=/api

# === Supabase Auth (JWT для проверки Bearer-токена фронтенда) ===
# Project Settings → API → JWT Secret (legacy HS256 projects)
SUPABASE_JWT_SECRET=
# Базовый URL проекта (без /rest/v1) — нужен для JWKS и fallback-проверки через Auth API
SUPABASE_URL=
# Project Settings → API → anon / publishable key — fallback-проверка токена через /auth/v1/user
SUPABASE_ANON_KEY=

# Project Settings → API → service_role key — для OAuth Mail.ru (backend создаёт сессию)
SUPABASE_SERVICE_ROLE_KEY=

# Mail.ru OAuth — https://oauth.mail.ru/
# Redirect URI (должен совпадать в oauth.mail.ru; localhost ≠ 127.0.0.1):
MAILRU_REDIRECT_URI=http://localhost:5173/api/auth/mailru/callback
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=

# Email через запятую — superuser для Notion delete и /api/me
SUPERUSER_EMAILS=kondratovic91@mail.ru

# E2E Playwright (не коммитить пароль) — обычный вход email/пароль для notion-delete.spec
# E2E_SUPERUSER_EMAIL=kondratovic91@mail.ru
# E2E_SUPERUSER_PASSWORD=

# Dev: принудительная страна для /api/auth/country (ISO, напр. RU или DE)
GEO_COUNTRY_OVERRIDE=

# === Notion (обязательно для раздела «Результаты в Notion») ===
# Можно указать здесь или в корневом .env проекта
NOTION_SECRET=           # notion.so → Settings → Integrations → Internal Integration Token
NOTION_DATABASE_ID=      # ID базы из URL страницы Notion (32 символа, можно вставить ссылку)
NOTION_WEBHOOK_SECRET=     # секрет подписи webhook (если используете POST /api/notion/webhook)
NOTION_STARTUP_CHECK=true
NOTION_VERSION=2022-06-28
NOTION_TIMEOUT_SECONDS=15
