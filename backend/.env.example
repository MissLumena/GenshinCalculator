# === Сервер ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Разрешённые origin для CORS (фронтенд Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === JWT (смените в production!) ===
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Приложение ===
APP_NAME=Genshin DPS Calculator API
API_PREFIX=/api
