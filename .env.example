# Supabase (обязательно для работы с БД)
# Скопируйте в .env и подставьте значения из Supabase → Project Settings → API
# Только базовый URL проекта (без /rest/v1)
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → anon / publishable key
SUPABASE_ANON_KEY=your-anon-key
# Project Settings → API → JWT Secret (legacy HS256; для backend/.env тоже)
SUPABASE_JWT_SECRET=

# Notion (backend FastAPI — см. backend/.env.example)
NOTION_SECRET=
NOTION_DATABASE_ID=

# Email через запятую — автоматически superuser (если role не задан в Supabase)
SUPERUSER_EMAILS=kondratovic91@mail.ru

# То же для фронтенда (Vite)
VITE_SUPERUSER_EMAILS=kondratovic91@mail.ru

# Опционально: URL API при деплое без Vite proxy
# VITE_API_URL=

# Dev: эмуляция страны (ISO, напр. RU) для проверки блокировки OAuth
# VITE_GEO_COUNTRY_OVERRIDE=

# Supabase Dashboard → Authentication → Providers → Mail.ru (custom OAuth, slug: mailru)
# Redirect URL: https://your-app/auth/callback
#
# Вход через Mail.ru идёт через backend (/api/auth/mailru/*) — настройте MAILRU_* и
# SUPABASE_SERVICE_ROLE_KEY в backend/.env. Redirect URI в oauth.mail.ru:
# http://localhost:5173/api/auth/mailru/callback
