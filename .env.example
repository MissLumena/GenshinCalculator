# Supabase (обязательно для работы с БД)
# Скопируйте в .env и подставьте значения из Supabase → Project Settings → API
# Только базовый URL проекта (без /rest/v1)
SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → anon / publishable key
SUPABASE_ANON_KEY=your-anon-key

# Email владельца (для справки — реальное значение задаётся в Supabase SQL):
# UPDATE public.app_config SET value = 'you@example.com' WHERE key = 'owner_email';
OWNER_EMAIL=you@example.com
