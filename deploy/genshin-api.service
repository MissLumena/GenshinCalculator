[Unit]
Description=Genshin Calculator FastAPI
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/GenshinCalculator/backend
EnvironmentFile=/home/ubuntu/GenshinCalculator/backend/.env
ExecStart=/home/ubuntu/GenshinCalculator/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
