# Скопируйте на сервер: ~/GenshinCalculator/backend/.env

APP_HOST=127.0.0.1
APP_PORT=8010
APP_DEBUG=false

CORS_ORIGINS=https://YOUR_HOST

JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

APP_NAME=Genshin DPS Calculator API
API_PREFIX=/api

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=eyJ...

MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=
MAILRU_REDIRECT_URI=https://YOUR_HOST/api/auth/mailru/callback

SUPERUSER_EMAILS=your@email.ru

NOTION_SECRET=
NOTION_DATABASE_ID=
NOTION_STARTUP_CHECK=false
NOTION_VERSION=2022-06-28
NOTION_TIMEOUT_SECONDS=15
